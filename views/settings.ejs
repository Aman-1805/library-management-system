<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Settings' }) %>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen text-gray-800 dark:text-gray-200 flex flex-col antialiased transition-colors duration-300">
    
    <%- include('partials/navbar') %>

    <main class="flex-1 overflow-auto p-8 max-w-7xl mx-auto w-full">
        <header class="mb-8">
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Admin Settings</h2>
        </header>
        
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 max-w-lg w-full mx-auto">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Update Profile</h3>
            
            <div id="errorMsg" class="hidden bg-red-100 dark:bg-red-900/30 border border-red-400 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded relative mb-4 text-sm" role="alert"></div>
            <div id="successMsg" class="hidden bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-800 text-green-700 dark:text-green-400 px-4 py-3 rounded relative mb-4 text-sm" role="alert"></div>

            <form id="settingsForm" class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Username <span class="text-xs text-gray-400 dark:text-gray-500">(leave blank to keep current)</span></label>
                    <input type="text" id="username" class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg shadow-sm focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2 border">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Password <span class="text-xs text-gray-400 dark:text-gray-500">(leave blank to keep current)</span></label>
                    <input type="password" id="password" minlength="6" class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg shadow-sm focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2 border">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Confirm New Password</label>
                    <input type="password" id="confirmPassword" minlength="6" class="w-full border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg shadow-sm focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2 border">
                </div>
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 mt-4">
                    Save Changes
                </button>
            </form>
        </div>
    </main>

    <script>
        document.getElementById('settingsForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const errorMsg = document.getElementById('errorMsg'); const successMsg = document.getElementById('successMsg');
            errorMsg.classList.add('hidden'); successMsg.classList.add('hidden');
            const username = document.getElementById('username').value; const password = document.getElementById('password').value; const confirmPassword = document.getElementById('confirmPassword').value;
            if (!username && !password) { errorMsg.textContent = "Please fill at least one field."; errorMsg.classList.remove('hidden'); return; }
            if (password && password !== confirmPassword) { errorMsg.textContent = "Passwords do not match."; errorMsg.classList.remove('hidden'); return; }
            const payload = {}; if (username) payload.username = username; if (password) payload.password = password;
            const res = await api.request('/api/auth/profile', { method: 'PUT', body: JSON.stringify(payload) });
            if (res.ok) {
                successMsg.textContent = "Profile updated successfully!"; successMsg.classList.remove('hidden');
                document.getElementById('settingsForm').reset(); localStorage.setItem('token', res.data.token);
            } else { errorMsg.textContent = res.data.error || 'Failed to update'; errorMsg.classList.remove('hidden'); }
        });
    </script>
</body>
</html>
